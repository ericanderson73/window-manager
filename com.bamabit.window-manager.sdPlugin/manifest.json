{
	"Name": "Window Manager",
	"Version": "0.1.0.0",
	"Author": "Eric Anderson",
	"Actions": [
		{
			"Name": "Move Window Horizontally",
			"UUID": "com.bamabit.window-manager.move-horizontal",
			"Icon": "imgs/actions/dials/move-horizontal",
			"Tooltip": "Turn to move the selected window left or right.",
			"PropertyInspectorPath": "ui/window-adjustment.html",
			"Controllers": [
				"Encoder"
			],
			"States": [
				{
					"Image": "imgs/actions/counter/key",
					"TitleAlignment": "middle"
				}
			],
			"Encoder": {
				"Icon": "imgs/actions/dials/move-horizontal",
				"layout": "layouts/window-icon.json",
				"TriggerDescription": {
					"Rotate": "Move selected window horizontally"
				}
			}
		},
		{
			"Name": "Move Window Vertically",
			"UUID": "com.bamabit.window-manager.move-vertical",
			"Icon": "imgs/actions/dials/move-vertical",
